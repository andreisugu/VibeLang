@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="auth-card" style="text-align: center; padding: 3rem 2rem;">
        <div class="auth-icon-wrapper">
            <span class="auth-icon">👋</span>
        </div>
        <h1 class="auth-title" style="margin-top: 1rem;">See You Soon!</h1>
        <p class="auth-subtitle">You have been successfully signed out.</p>
        <div style="margin-top: 2rem;">
            <a asp-page="./Login" class="auth-submit-btn" style="display: inline-flex; text-decoration: none; width: auto; padding: 0.75rem 2rem;">
                <span class="auth-btn-text">Sign back in</span>
                <span class="auth-btn-icon">→</span>
            </a>
        </div>
    </div>
</div>
