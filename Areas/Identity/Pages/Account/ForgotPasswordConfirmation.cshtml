@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Forgot Password Confirmation";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="auth-card" style="text-align:center; padding:3rem 2rem;">
        <div class="auth-icon-wrapper"><span class="auth-icon">📬</span></div>
        <h1 class="auth-title" style="margin-top:1rem;">Check Your Email</h1>
        <p class="auth-subtitle">
            If an account with that email exists, we've sent a password reset link.<br />
            Please check your inbox and follow the instructions.
        </p>
        <div style="margin-top:2rem;">
            <a asp-page="./Login" class="auth-submit-btn" style="display:inline-flex; text-decoration:none; width:auto; padding:0.75rem 1.5rem;">
                <span class="auth-btn-text">Back to Login</span>
                <span class="auth-btn-icon">→</span>
            </a>
        </div>
    </div>
</div>
