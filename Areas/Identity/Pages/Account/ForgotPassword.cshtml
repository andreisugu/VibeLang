@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-icon-wrapper"><span class="auth-icon">🔑</span></div>
            <h1 class="auth-title">Forgot Password?</h1>
            <p class="auth-subtitle">Enter your email to receive a reset link</p>
        </div>

        <form id="forgot-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-error-summary" role="alert"></div>
            <div class="auth-form-body">
                <div class="auth-field">
                    <label asp-for="Input.Email" class="auth-label">Email Address</label>
                    <div class="auth-input-wrapper">
                        <span class="auth-input-icon">✉️</span>
                        <input asp-for="Input.Email" id="email" class="auth-input" autocomplete="username" placeholder="your@email.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="auth-field-error"></span>
                </div>
                <button id="forgot-password-submit" type="submit" class="auth-submit-btn">
                    <span class="auth-btn-text">Send Reset Link</span>
                    <span class="auth-btn-icon">→</span>
                </button>
            </div>
        </form>

        <div class="auth-card-footer">
            <p class="auth-footer-text">
                Remembered your password?
                <a asp-page="./Login" class="auth-link">Sign in</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
