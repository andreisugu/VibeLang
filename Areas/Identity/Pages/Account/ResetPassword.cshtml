@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-icon-wrapper"><span class="auth-icon">🔒</span></div>
            <h1 class="auth-title">Reset Password</h1>
            <p class="auth-subtitle">Enter a new password for your account</p>
        </div>

        <form id="reset-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-error-summary" role="alert"></div>
            <input asp-for="Input.Code" type="hidden" />
            <div class="auth-form-body">
                <div class="auth-field">
                    <label asp-for="Input.Email" class="auth-label">Email Address</label>
                    <div class="auth-input-wrapper">
                        <span class="auth-input-icon">✉️</span>
                        <input asp-for="Input.Email" id="reset-email" class="auth-input" autocomplete="username" placeholder="your@email.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label asp-for="Input.Password" class="auth-label">New Password</label>
                    <div class="auth-input-wrapper">
                        <span class="auth-input-icon">🔒</span>
                        <input asp-for="Input.Password" id="reset-password" class="auth-input" autocomplete="new-password" placeholder="At least 6 characters" />
                    </div>
                    <span asp-validation-for="Input.Password" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label asp-for="Input.ConfirmPassword" class="auth-label">Confirm New Password</label>
                    <div class="auth-input-wrapper">
                        <span class="auth-input-icon">🔒</span>
                        <input asp-for="Input.ConfirmPassword" id="reset-confirm-password" class="auth-input" autocomplete="new-password" placeholder="Repeat new password" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="auth-field-error"></span>
                </div>
                <button id="reset-password-submit" type="submit" class="auth-submit-btn">
                    <span class="auth-btn-text">Reset Password</span>
                    <span class="auth-btn-icon">→</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
