@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="auth-card" style="text-align:center; padding:3rem 2rem;">
        <div class="auth-icon-wrapper">
            <span class="auth-icon">🚫</span>
        </div>
        <h1 class="auth-title" style="margin-top:1rem; color:#ef4444;">Access Denied</h1>
        <p class="auth-subtitle" style="color:#6b7280;">
            You do not have permission to view this page.
        </p>
        <div style="margin-top:2rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
            <a asp-controller="Home" asp-action="Index" class="auth-submit-btn" style="display:inline-flex; text-decoration:none; width:auto; padding:0.75rem 1.5rem;">
                <span class="auth-btn-text">Go Home</span>
                <span class="auth-btn-icon">🏠</span>
            </a>
        </div>
    </div>
</div>
