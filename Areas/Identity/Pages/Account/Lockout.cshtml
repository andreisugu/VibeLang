@page
@model LockoutModel
@{
    ViewData["Title"] = "Locked Out";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="auth-card" style="text-align:center; padding:3rem 2rem;">
        <div class="auth-icon-wrapper"><span class="auth-icon">🔐</span></div>
        <h1 class="auth-title" style="margin-top:1rem; color:#ef4444;">Account Locked</h1>
        <p class="auth-subtitle">
            This account has been locked due to multiple failed sign-in attempts.<br />
            Please try again in a few minutes.
        </p>
        <div style="margin-top:2rem;">
            <a asp-controller="Home" asp-action="Index" class="auth-submit-btn" style="display:inline-flex; text-decoration:none; width:auto; padding:0.75rem 1.5rem;">
                <span class="auth-btn-text">Go Home</span>
                <span class="auth-btn-icon">🏠</span>
            </a>
        </div>
    </div>
</div>
