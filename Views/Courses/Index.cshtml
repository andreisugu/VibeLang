@model IEnumerable<VibeLang.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h1 class="h4">Courses (Admin)</h1>

<p>
    <a asp-action="Create" class="btn btn-primary rounded-pill">Create New Course</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>ISO Code</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Title</td>
            <td>@item.IsoCode</td>
            <td>@item.Description</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
