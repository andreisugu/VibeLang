<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VibeLang Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/icons/favicon.png">
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <!-- Main Top Navbar (Global) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3 shadow-sm">
        <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
            <img src="~/assets/icons/vibelang_transparent_1024.png" alt="VibeLang" class="navbar-logo me-2" style="height: 30px; filter: brightness(0) invert(1);">
            <span class="vibelang-title">VibeLang Admin</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminNavbar">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Back to Site</a>
                </li>
                <li class="nav-item ms-lg-3">
                    <partial name="_LoginPartial" />
                </li>
            </ul>
        </div>
    </nav>

    <!-- Admin Sub-navigation Bar -->
    <nav class="navbar navbar-expand navbar-light bg-white border-bottom shadow-sm py-0 mb-4">
        <div class="container-fluid overflow-auto">
            <ul class="navbar-nav mx-auto text-nowrap">
                <li class="nav-item mx-2">
                    <a class="nav-link py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active border-bottom border-primary border-3" : "")" 
                       asp-controller="Admin" asp-action="Index">Dashboard</a>
                </li>
                <li class="nav-item mx-2">
                    <a class="nav-link py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Courses" ? "active border-bottom border-primary border-3" : "")" 
                       asp-controller="Courses" asp-action="Index">Courses</a>
                </li>
                <li class="nav-item mx-2">
                    <a class="nav-link py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chapters" ? "active border-bottom border-primary border-3" : "")" 
                       asp-controller="Chapters" asp-action="Index">Chapters</a>
                </li>
                <li class="nav-item mx-2">
                    <a class="nav-link py-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Lessons" ? "active border-bottom border-primary border-3" : "")" 
                       asp-controller="Lessons" asp-action="Index">Lessons</a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Admin Content Area -->
    <main role="main" class="container pb-5">
        @RenderBody()
    </main>

    <footer class="bg-white text-center py-3 mt-auto border-top">
        <small class="text-muted">&copy; 2026 - VibeLang Administrative Panel</small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
