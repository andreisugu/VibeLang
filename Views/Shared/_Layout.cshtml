<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VibeLang</title>
    <!-- Bootstrap framework for styling and grid layout -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom branding and logo styles -->
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/icons/favicon.png">
    <link rel="apple-touch-icon" sizes="180x180" href="~/assets/icons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="~/assets/icons/icon-192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="~/assets/icons/icon-512.png">
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- Navigation bar -->
    <nav class="navbar navbar-light bg-light px-3">
        <!-- Brand logo and title -->
        <a class="navbar-brand me-3" asp-controller="Home" asp-action="Index">
            <img src="~/assets/icons/vibelang_transparent_1024.png" alt="VibeLang" class="navbar-logo" style="height: 40px;">
            <span class="vibelang-title">VibeLang</span>
        </a>
        <!-- Navigation links -->
        <a class="nav-link mx-2" asp-controller="Home" asp-action="Index">Dashboard</a>
        <a class="nav-link mx-2" asp-controller="Home" asp-action="Courses">Courses</a>
        <a class="nav-link mx-2" asp-controller="Home" asp-action="Leaderboard">Leaderboard</a>
        <!-- User info pushed to right side -->
        <span class="ms-auto me-2">Sugubete Andrei | sugubete.andrei@email.com</span>
        <a class="nav-link ms-2" asp-controller="Home" asp-action="Profile">Profile</a>
    </nav>

    <!-- Main content area -->
    <main role="main" class="container my-4">
        @RenderBody()
    </main>

    <!-- Footer at bottom -->
    <footer class="bg-light text-center py-2 mt-auto border-top">
        &copy; 2026 - VibeLang
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
