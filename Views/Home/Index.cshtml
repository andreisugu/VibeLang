@model VibeLang.Models.UserCourseStats

@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="h4">Welcome back, @(ViewBag.FirstName)!</h1>
<!-- row: grid container, col: auto-sized equal width columns, mt-4: top margin -->
<div class="row mt-4">
    <!-- Stats card -->
    <div class="col">
        <!-- card: content container, shadow-sm: subtle shadow, text-center: centered text -->
        <div class="card text-center shadow-sm">
            <div class="card-body">@(Model?.CurrentStreak ?? 0) days</div>
        </div>
    </div>
    <!-- Stats card -->
    <div class="col">
        <div class="card text-center shadow-sm">
            <div class="card-body">@(Model?.TotalXP ?? 0) XP</div>
        </div>
    </div>
    <!-- Button to resume last lesson -->
    <div class="col">
        @if (ViewBag.ContinueLesson != null)
        {
            var lesson = ViewBag.ContinueLesson as VibeLang.Models.Lesson;
            <div class="card shadow-sm border-0 mb-2">
                <div class="card-body py-2 px-3 small">
                    <div class="text-muted fw-bold text-uppercase" style="font-size: 0.7rem;">Last Active:</div>
                    <div class="text-primary truncate">@lesson?.Chapter?.Course?.Title</div>
                    <div class="text-secondary truncate">@lesson?.Chapter?.Title</div>
                    <div class="fw-bold truncate">@lesson?.Title</div>
                </div>
            </div>
        }
        <!-- w-100: full width, rounded-pill: rounded button -->
        <a asp-controller="Home" asp-action="Lesson" asp-route-id="@ViewBag.LastLessonId" class="btn btn-primary rounded-pill w-100">Continue last lesson</a>
    </div>
</div>
