@model IEnumerable<VibeLang.Models.UserCourseStats>

@{
    ViewData["Title"] = "Leaderboard";
}

<!-- table-sm: compact table with reduced padding -->
<table class="table table-sm">
    <!-- Header row -->
    <thead>
        <tr>
            <th>Rank</th>
            <th>User ID</th>
            <th>Language</th>
            <th>XP Points</th>
        </tr>
    </thead>
    <!-- Data rows -->
    <tbody>
        @{
            int rank = 1;
        }
        @foreach (var item in Model)
        {
            <!-- table-active: highlights current user's row (mock UserId 1) -->
            <tr class="@(item.UserId == 1 ? "table-active" : "")">
                <td>@rank</td>
                <td>User #@item.UserId</td>
                <td>@(item.Course?.Title ?? "N/A")</td>
                <td>@item.TotalXP</td>
            </tr>
            rank++;
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center">No data available.</td>
            </tr>
        }
    </tbody>
</table>
