@{
    ViewData["Title"] = "Profile";
}

<div class="row">
    <!-- col-4: 1/3 width column-->
    <div class="col-4 text-center">
        <!-- rounded-circle: circular element, mx-auto: center horizontally -->
        <div class="rounded-circle bg-secondary mx-auto mb-2" style="width:80px;height:80px;"></div>
        <div>Sugubete Andrei</div>
    </div>
    <!-- col-8: 2/3 width column -->
    <div class="col-8">
        <!-- form-control: styled input field -->
        <form>
            <input class="form-control mb-2" type="text" placeholder="Name" value="Sugubete Andrei">
            <!-- type="email": validates email format -->
            <input class="form-control mb-2" type="email" placeholder="Email" value="sugubete.andrei@email.com">
            <button class="btn btn-primary" type="button">Save data</button>
        </form>
    </div>
</div>
