@using Microsoft.AspNetCore.Identity
@inject UserManager<VibeLang.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Profile";
    var user = await UserManager.GetUserAsync(User);
}

<h1 class="h4 mb-4">Your Profile</h1>

<div class="row">
    <!-- col-4: 1/3 width column-->
    <div class="col-md-4 text-center mb-4">
        <!-- rounded-circle: circular element, mx-auto: center horizontally -->
        <div class="rounded-circle bg-secondary mx-auto mb-3 d-flex align-items-center justify-content-center text-white h1" style="width:100px;height:100px;">
            @(user?.FirstName?[0].ToString().ToUpper() ?? user?.UserName?[0].ToString().ToUpper() ?? "?")
        </div>
        <div class="fw-bold">@user?.UserName</div>
        <div class="text-muted small">@user?.Email</div>
    </div>
    
    <!-- col-8: 2/3 width column -->
    <div class="col-md-8">
        @if (TempData["StatusMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["StatusMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-action="UpdateProfile" method="post">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">First Name</label>
                        <input name="FirstName" class="form-control" type="text" placeholder="First Name" value="@user?.FirstName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Last Name</label>
                        <input name="LastName" class="form-control" type="text" placeholder="Last Name" value="@user?.LastName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email (Read-only)</label>
                        <input class="form-control" type="email" value="@user?.Email" disabled>
                    </div>
                    <button class="btn btn-primary rounded-pill px-4" type="submit">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>
