@model IEnumerable<VibeLang.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h1 class="h4">Your Learning Paths</h1>
<a asp-controller="Home" asp-action="Vocabulary" class="btn btn-link p-0 mb-3">Mastered Vocabulary</a>

<div class="row mt-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info">No courses available. Start by adding a Language and a Course!</div>
        </div>
    }
    else
    {
        @foreach (var course in Model)
        {
            var totalLessons = course.Chapters.SelectMany(ch => ch.Lessons).Count();
            var completedInCourse = course.Chapters.SelectMany(ch => ch.Lessons)
                                     .Count(l => ((List<int>)ViewBag.CompletedLessonIds).Contains(l.Id));
            var coursePercent = totalLessons > 0 ? (int)((double)completedInCourse / totalLessons * 100) : 0;

            <div class="col-12 mb-5">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                        <h2 class="h5 mb-0">@course.Title</h2>
                        <span class="badge bg-white text-primary rounded-pill">@coursePercent% Complete</span>
                    </div>
                    <div class="card-body bg-light">
                        <div class="progress mb-4" style="height: 10px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @coursePercent%;" 
                                 aria-valuenow="@coursePercent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        @if (!course.Chapters.Any())
                        {
                            <p class="text-muted italic">This course is coming soon...</p>
                        }
                        else
                        {
                            <div class="row">
                                @foreach (var chapter in course.Chapters)
                                {
                                    var chapterLessons = chapter.Lessons.Count();
                                    var chapterCompleted = chapter.Lessons.Count(l => ((List<int>)ViewBag.CompletedLessonIds).Contains(l.Id));
                                    var chapterPercent = chapterLessons > 0 ? (int)((double)chapterCompleted / chapterLessons * 100) : 0;

                                    <div class="col-md-6 mb-4">
                                        <div class="card h-100 border-0 shadow-sm">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                                                    <h3 class="h6 text-uppercase fw-bold text-muted mb-0">@chapter.Title</h3>
                                                    <small class="text-primary fw-bold">@chapterPercent%</small>
                                                </div>
                                                
                                                <div class="progress mb-3" style="height: 5px;">
                                                    <div class="progress-bar bg-info" role="progressbar" style="width: @chapterPercent%;" 
                                                         aria-valuenow="@chapterPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>

                                                <div class="list-group list-group-flush">
                                                    @foreach (var lesson in chapter.Lessons)
                                                    {
                                                        bool isDone = ((List<int>)ViewBag.CompletedLessonIds).Contains(lesson.Id);
                                                        <a asp-action="Lesson" asp-route-id="@lesson.Id" 
                                                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0">
                                                            <span>
                                                                @if (isDone)
                                                                {
                                                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="bi bi-play-circle-fill text-primary me-2"></i>
                                                                }
                                                                @lesson.Title
                                                            </span>
                                                            @if (isDone)
                                                            {
                                                                <span class="badge bg-success-soft text-success rounded-pill small">Done</span>
                                                            }
                                                        </a>
                                                    }
                                                    @if (!chapter.Lessons.Any())
                                                    {
                                                        <div class="text-muted small">No lessons yet.</div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
