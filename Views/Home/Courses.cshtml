@model IEnumerable<VibeLang.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<h1 class="h4">Your Learning Paths</h1>
<a asp-controller="Home" asp-action="Vocabulary" class="btn btn-link p-0 mb-3">Mastered Vocabulary</a>

<div class="row mt-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info">No courses available. Start by adding a Language and a Course!</div>
        </div>
    }
    else
    {
        @foreach (var course in Model)
        {
            <div class="col-12 mb-5">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white py-3">
                        <h2 class="h5 mb-0">@course.Title</h2>
                    </div>
                    <div class="card-body bg-light">
                        @if (!course.Chapters.Any())
                        {
                            <p class="text-muted italic">This course is coming soon...</p>
                        }
                        else
                        {
                            <div class="row">
                                @foreach (var chapter in course.Chapters)
                                {
                                    <div class="col-md-6 mb-4">
                                        <div class="card h-100 border-0 shadow-sm">
                                            <div class="card-body">
                                                <h3 class="h6 text-uppercase fw-bold text-muted border-bottom pb-2">@chapter.Title</h3>
                                                <div class="list-group list-group-flush mt-2">
                                                    @foreach (var lesson in chapter.Lessons)
                                                    {
                                                        <a asp-action="Lesson" asp-route-id="@lesson.Id" 
                                                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 px-0">
                                                            <span>
                                                                <i class="bi bi-play-circle-fill text-primary me-2"></i> @lesson.Title
                                                            </span>
                                                        </a>
                                                    }
                                                    @if (!chapter.Lessons.Any())
                                                    {
                                                        <div class="text-muted small">No lessons yet.</div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
