@{
    ViewData["Title"] = "Quiz";
}

<!-- Quiz question -->
<h3 class="mb-4">What does "Ghosting" mean?</h3>
<!-- list-group: Bootstrap list of items, mb-3: bottom margin -->
<div class="list-group mb-3">
    <!-- list-group-item-action: makes item interactive/hoverable -->
    <button class="list-group-item list-group-item-action">Fantasma</button>
    <button class="list-group-item list-group-item-action">Ignorar</button>
    <button class="list-group-item list-group-item-action">Bailar</button>
</div>
<!-- rounded-pill: button with curved edges -->
<button class="btn btn-primary rounded-pill">Check</button>
