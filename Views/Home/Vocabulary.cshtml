@model IEnumerable<VibeLang.Models.VocabularyWord>

@{
    ViewData["Title"] = "Vocabulary";
    var userProgress = ViewBag.UserProgress as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<h1 class="h4">Vocabulary</h1>

@if (User?.Identity?.IsAuthenticated == false)
{
    <div class="alert alert-info">
        Please <a asp-area="Identity" asp-page="/Account/Login">log in</a> to view your vocabulary words from completed lessons.
    </div>
}
else if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        Complete some lessons to build your vocabulary! Your learned words will appear here.
    </div>
}
else
{
    <ul id="vocabulary-list" class="list-group">
        @foreach (var word in Model)
        {
            userProgress.TryGetValue(word.Id, out var status);
            status = status ?? "New";
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@word.Word</strong>
                    <span class="text-muted ms-2">- @word.Translation</span>
                </div>
                <span class="badge @(status == "Learned" ? "bg-success" : "bg-secondary")">@status</span>
            </li>
        }
    </ul>
}

